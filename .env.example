# ─── Site address ──────────────────────────────────────────────────────────
# Production (HTTPS via Let's Encrypt): the public domain
SITE_ADDRESS=www.blackrosealliance.com, blackrosealliance.com
SITE_ADDRESS_URL=https://www.blackrosealliance.com
#
# Local stack testing: HTTP only on port 80
# SITE_ADDRESS=:80
# SITE_ADDRESS_URL=http://localhost

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=rally_lead
POSTGRES_PASSWORD=change_me_to_something_long_and_random
POSTGRES_DB=rally_lead

# ─── Clerk ─────────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API keys
# Publishable key is baked into the React bundle (build arg), secret key stays server-side.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
