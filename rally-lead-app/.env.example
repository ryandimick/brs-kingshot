# Clerk publishable key — get from https://dashboard.clerk.com → API Keys
# (Build-time only; Vite bakes this into the bundle.)
VITE_CLERK_PUBLISHABLE_KEY=

# API base URL.
#   Local dev (vite on :5173 hitting api on :3001):   http://localhost:3001
#   Production (single domain, Caddy strips /api):    /api
VITE_API_BASE_URL=http://localhost:3001
